# Neon connection string (Dashboard → Connection details → pooled recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Long random string used to sign admin JWTs
JWT_SECRET=change-me-to-a-long-random-secret

# API listen port (Vite proxies /api and /uploads here)
PORT=8787

# Where uploaded images are stored on disk (used only when Cloudinary is not set)
UPLOAD_DIR=uploads

# Public base URL for local uploaded files (dev: Vite origin so /uploads is proxied)
PUBLIC_BASE_URL=http://localhost:5173

# ── Cloudinary (free temporary media storage) ───────────────────
# Sign up: https://cloudinary.com/users/register_free
# Dashboard → Account Details / API Keys
# When these three are set, uploads go to Cloudinary (works on Vercel).
# Leave empty to keep using local disk (localhost only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix in your Cloudinary Media Library
CLOUDINARY_FOLDER=hamel

# Browser origins allowed to call this API (comma-separated). Add your Vercel URL:
# CORS_ORIGINS=https://hamel.vercel.app,https://hamel-git-main-xxx.vercel.app
CORS_ORIGINS=

# Required on Vercel when the API runs as a serverless function (Hono POST/login)
# NODEJS_HELPERS=0

# Optional: expose reset tokens in forgot-password JSON (local/dev only)
DEV_EXPOSE_RESET_TOKEN=true

# ── AI chat assist ──────────────────────────────────────────────
# Provider: claude (sample/default) | gemini (switch later for client)
AI_PROVIDER=claude

# Anthropic (Claude) — required when AI_PROVIDER=claude
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Gemini — required when AI_PROVIDER=gemini
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Messenger Platform (Page → customer confirmations) ──────────
# 1. Meta Developer App → Messenger → generate Page access token
# 2. Webhook callback: https://YOUR_PUBLIC_API/api/messenger/webhook
# 3. Verify token must match below; subscribe to messages, messaging_referrals, messaging_postbacks
# 4. Local dev: expose API with ngrok/cloudflare tunnel (Meta requires HTTPS)
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=hamel_messenger_verify
MESSENGER_PAGE_USERNAME=hameltrading
